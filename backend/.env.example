# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pyrmit

# LLM / AI Gateway
# Use Vercel AI Gateway (preferred) — set AI_GATEWAY_API_KEY
# Fall back to direct OpenAI — set OPENAI_API_KEY
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=

# Mistral (required for PDF OCR)
MISTRAL_API_KEY=

# Supabase (required for chunk ingestion)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Auth
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Access gate
ACCESS_GATE_PASSWORD=

# Environment — controls which chat model is used
# development: openai/gpt-5.4-nano
# production:  openai/gpt-5.4-mini
APP_ENV=development

# Deployment (optional)
# ACCESS_GATE_COOKIE_DOMAIN=.yourdomain.com
# ACCESS_GATE_COOKIE_SECURE=true
# ACCESS_GATE_COOKIE_SAMESITE=lax
